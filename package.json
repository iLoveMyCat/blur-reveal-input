{
  "name": "blur-reveal-input",
  "version": "1.0.0",
  "description": "Password input with blur effect that can be selectively revealed",
  "main": "dist/blur-reveal-input.js",
  "module": "dist/blur-reveal-input.esm.js",
  "types": "dist/blur-reveal-input.d.ts",
  "exports": {
    ".": {
      "types": "./dist/blur-reveal-input.d.ts",
      "import": "./dist/blur-reveal-input.esm.js",
      "require": "./dist/blur-reveal-input.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "vite",
    "build": "rollup -c",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "typecheck": "tsc --noEmit",
    "prepare": "npm run build"
  },
  "devDependencies": {
    "@playwright/test": "^1.40.0",
    "@rollup/plugin-terser": "^0.4.4",
    "@rollup/plugin-typescript": "^11.1.5",
    "@types/node": "^20.10.0",
    "@typescript-eslint/eslint-plugin": "^6.13.0",
    "@typescript-eslint/parser": "^6.13.0",
    "@vitest/coverage-v8": "^1.0.0",
    "@vitest/ui": "^1.0.0",
    "eslint": "^8.55.0",
    "eslint-config-prettier": "^9.1.0",
    "jsdom": "^23.0.0",
    "prettier": "^3.1.0",
    "rollup": "^4.6.0",
    "rollup-plugin-dts": "^6.1.0",
    "terser": "^5.24.0",
    "tslib": "^2.8.1",
    "typescript": "^5.3.2",
    "vite": "^5.0.4",
    "vitest": "^1.0.0"
  },
  "keywords": [
    "password",
    "input",
    "blur",
    "reveal",
    "security",
    "ux",
    "form",
    "accessibility",
    "password-input",
    "blur-reveal",
    "password-field",
    "vanilla-js",
    "web-component",
    "react",
    "vue",
    "angular",
    "svelte",
    "css-blur",
    "touch",
    "mobile"
  ],
  "author": "Arik Shalito (https://github.com/iLoveMyCat)",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/iLoveMyCat/blur-reveal-input.git"
  },
  "bugs": {
    "url": "https://github.com/iLoveMyCat/blur-reveal-input/issues"
  },
  "homepage": "https://github.com/iLoveMyCat/blur-reveal-input#readme",
  "engines": {
    "node": ">=18.0.0"
  }
}
